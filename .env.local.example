# Supabase project credentials — find them at
# https://supabase.com/dashboard/project/_/settings/api-keys
# Copy this file to .env.local and fill in the values.
#
# Use the PUBLISHABLE key (sb_publishable_... or the legacy anon key).
# NEVER put the secret key (sb_secret_...) here — it bypasses row-level
# security and must not be exposed to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
